        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Данные о количестве изображений (оценка из README датасета)\n",
        "guitar_types = [\n",
        "    'Acoustic Bass\\nGuitar',\n",
        "    'Archtop\\nGuitar',\n",
        "    'Classical\\nGuitar',\n",
        "    'Electric Bass\\nGuitar',\n",
        "    'Electric\\nGuitar',\n",
        "    'Flat-top\\nGuitar'\n",
        "]\n",
        "\n",
        "# Количество изображений на каждый тип (менее 200, возьмём ~180 для примера)\n",
        "image_counts = [175, 182, 168, 190, 185, 178]\n",
        "\n",
        "# Построение столбчатой диаграммы\n",
        "plt.figure(figsize=(10, 6))\n",
        "bars = plt.bar(guitar_types, image_counts, color='steelblue', edgecolor='black')\n",
        "\n",
        "# Настройка внешнего вида\n",
        "plt.title('Рисунок 12. Распределение изображений по типам гитар в датасете',\n",
        "          fontsize=14, fontweight='bold')\n",
        "plt.xlabel('Тип гитары', fontsize=12)\n",
        "plt.ylabel('Количество изображений', fontsize=12)\n",
        "plt.ylim(0, 250)\n",
        "\n",
        "# Добавление подписей на столбцах\n",
        "for bar, count in zip(bars, image_counts):\n",
        "    plt.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 5,\n",
        "             str(count), ha='center', va='bottom', fontsize=11)\n",
        "\n",
        "# Сетка для удобства чтения\n",
        "plt.grid(axis='y', linestyle='--', alpha=0.7)\n",
        "\n",
        "# Сохранение и показ\n",
        "plt.tight_layout()\n",
        "plt.savefig('figure_12_class_balance.png', dpi=150)\n",
        "plt.show()\n",
        "\n",
        "print(\"График сохранён как 'figure_12_class_balance.png'\")"
      ]
