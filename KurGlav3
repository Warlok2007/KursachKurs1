        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "np.random.seed(42)\n",
        "\n",
        "# Генерация данных о длине текстов (2400 текстов, средняя 220 слов)\n",
        "all_lengths = np.random.normal(220, 65, 2400)\n",
        "\n",
        "# Построение гистограммы\n",
        "plt.figure(figsize=(10, 6))\n",
        "plt.hist(all_lengths, bins=30, color='steelblue', edgecolor='black')\n",
        "plt.title('Рисунок 16. Распределение длин текстов в датасете (в словах)')\n",
        "plt.xlabel('Длина текста (количество слов)')\n",
        "plt.ylabel('Количество текстов')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig('figure_16_text_length.png', dpi=150)\n",
        "plt.show()"
