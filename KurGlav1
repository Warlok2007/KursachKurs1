        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "import plotly.express as px\n",
        "\n",
        "sns.set_style(\"whitegrid\")\n",
        "\n",
        "url = 'https://raw.githubusercontent.com/RiahiVahid/Framingham-Heart-study-dataset/master/framingham_heart_disease.csv'\n",
        "df = pd.read_csv(url)\n",
        "\n",
        "print(\"1.2.1 Диаграммы распределения\")\n",
        "numeric_cols = ['age', 'totChol', 'sysBP', 'BMI', 'glucose']\n",
        "fig, axes = plt.subplots(2, 3, figsize=(15, 8))\n",
        "axes = axes.ravel()\n",
        "for i, col in enumerate(numeric_cols):\n",
        "    axes[i].hist(df[col].dropna(), bins=30, edgecolor='black', color='skyblue')\n",
        "    axes[i].set_title(col)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "print(\"1.2.2 Визуализация признаков средствами библиотеки Seaborn\")\n",
        "\n",
        "plt.figure(figsize=(10,6))\n",
        "sns.boxplot(data=df, x='TenYearCHD', y='sysBP')\n",
        "plt.title('Систолическое давление по группе TenYearCHD')\n",
        "plt.show()\n",
        "\n",
        "plt.figure(figsize=(10,6))\n",
        "sns.violinplot(data=df, x='male', y='BMI')\n",
        "plt.title('ИМТ по полу')\n",
        "plt.show()\n",
        "\n",
        "plt.figure(figsize=(10,6))\n",
        "sns.scatterplot(data=df, x='age', y='totChol', hue='TenYearCHD', alpha=0.6)\n",
        "plt.title('Возраст и холестерин')\n",
        "plt.show()\n",
        "\n",
        "print(\"1.2.3 Визуализация признаков средствами библиотеки Plotly\")\n",
        "fig1 = px.scatter(df, x='age', y='sysBP', color='TenYearCHD', title='Возраст и давление')\n",
        "fig1.show()\n",
        "fig2 = px.histogram(df, x='totChol', nbins=50, title='Распределение холестерина')\n",
        "fig2.show()\n",
        "\n",
        "print(\"1.2.4 Обработка строк с нулевыми значениями\")\n",
        "print(\"Пропуски до обработки\")\n",
        "print(df[['glucose', 'totChol', 'cigsPerDay', 'BMI', 'education', 'heartRate']].isnull().sum())\n",
        "\n",
        "for col in ['totChol', 'BMI', 'cigsPerDay', 'glucose', 'heartRate']:\n",
        "    if col in df.columns:\n",
        "        df[col] = df[col].fillna(df[col].median())\n",
        "if 'education' in df.columns:\n",
        "    df['education'] = df['education'].fillna(df['education'].mode()[0])\n",
        "df = df.dropna()\n",
        "print(\"Пропуски после обработки\", df.isnull().sum().sum())\n",
        "\n",
        "print(\"1.2.5 Построение тепловой карты\")\n",
        "plt.figure(figsize=(12, 8))\n",
        "corr = df[['age', 'totChol', 'sysBP', 'diaBP', 'BMI', 'heartRate', 'glucose', 'TenYearCHD']].corr()\n",
        "sns.heatmap(corr, annot=True, cmap='coolwarm', fmt='.2f')\n",
        "plt.title('Матрица корреляций числовых признаков')\n",
        "plt.show()\n",
        "\n",
        "plt.figure(figsize=(12, 4))\n",
        "df_before = pd.read_csv(url)\n",
        "sns.heatmap(df_before[['glucose', 'totChol', 'cigsPerDay', 'BMI', 'education', 'heartRate']].isnull(),\n",
        "            cbar=False, yticklabels=False, cmap='viridis')\n",
        "plt.title('Тепловая карта пропущенных значений')\n",
        "plt.show()\n",
        "\n",
        "print(\"1.2.6 Устранение дубликатов строк\")\n",
        "print(\"Дубликатов\", df.duplicated().sum())\n",
        "\n",
        "print(\"1.2.7 Выявление нетипичных выбросов по признакам\")\n",
        "for col in ['totChol', 'sysBP', 'BMI', 'glucose']:\n",
        "    Q1 = df[col].quantile(0.25)\n",
        "    Q3 = df[col].quantile(0.75)\n",
        "    IQR = Q3 - Q1\n",
        "    outliers = df[(df[col] < Q1 - 1.5*IQR) | (df[col] > Q3 + 1.5*IQR)]\n",
        "    print(col, len(outliers))\n",
        "\n",
        "fig, axes = plt.subplots(1, 4, figsize=(16, 4))\n",
        "for i, col in enumerate(['totChol', 'sysBP', 'BMI', 'glucose']):\n",
        "    axes[i].boxplot(df[col].dropna())\n",
        "    axes[i].set_title(col)\n",
        "plt.show()\n",
        "\n",
        "print(\"1.2.8 Условная фильтрация сэмплов\")\n",
        "filter1 = df[(df['age'] > 60) & (df['prevalentHyp'] == 1) & (df['diabetes'] == 1)]\n",
        "print(\"Пожилые с гипертонией и диабетом\", len(filter1))\n",
        "filter2 = df[(df['male'] == 0) & (df['currentSmoker'] == 1) & (df['totChol'] > 240)]\n",
        "print(\"Курящие женщины с высоким холестерином\", len(filter2))\n",
        "filter3 = df[(df['age'] < 40) & (df['currentSmoker'] == 0) & (df['BMI'] < 25)]\n",
        "print(\"Молодые без факторов риска\", len(filter3))\n",
        "\n",
        "print(\"1.2.9 Добавление шума\")\n",
        "np.random.seed(42)\n",
        "df['BMI_noisy'] = df['BMI'] + np.random.normal(0, 1, len(df))\n",
        "df['heartRate_noisy'] = df['heartRate'] + np.random.normal(0, 2, len(df))\n",
        "print(df[['BMI', 'BMI_noisy', 'heartRate', 'heartRate_noisy']].head())\n",
        "\n",
        "print(\"1.2.10 Преобразование числовых данных в категориальные\")\n",
        "df['age_group'] = pd.cut(df['age'], bins=[30,40,50,60,70], labels=['30-39','40-49','50-59','60-69'])\n",
        "df['BMI_category'] = pd.cut(df['BMI'], bins=[0,18.5,25,30,100], labels=['Underweight','Normal','Overweight','Obese'])\n",
        "print(df['age_group'].value_counts())\n",
        "print(df['BMI_category'].value_counts())\n",
        "\n",
        "print(\"1.2.11 Дополнительные преобразования\")\n",
        "education_desc = {1: 'High School', 2: 'Some College', 3: 'College', 4: 'Post-Grad'}\n",
        "df['education_desc'] = df['education'].map(education_desc)\n",
        "print(df[['education', 'education_desc']].head())\n",
        "\n",
        "print(\"1.2.12 Оценка изменения в данных после фильтрации\")\n",
        "fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
        "df['BMI'].hist(bins=30, ax=axes[0], edgecolor='black')\n",
        "axes[0].set_title('Распределение BMI исходное')\n",
        "df['BMI_noisy'].hist(bins=30, ax=axes[1], edgecolor='black', color='orange')\n",
        "axes[1].set_title('Распределение BMI с шумом')\n",
        "plt.show()\n",
        "\n",
        "print(\"1.2.13 Запросы на группировку\")\n",
        "grouped = df.groupby('age_group').agg({\n",
        "    'TenYearCHD': 'mean',\n",
        "    'sysBP': 'mean',\n",
        "    'totChol': 'mean',\n",
        "    'age': 'count'\n",
        "}).round(3)\n",
        "grouped.columns = ['Доля CHD', 'Среднее сист давление', 'Средний холестерин', 'Количество']\n",
        "print(grouped)\n",
        "\n",
        "print(\"1.3 Характеристика категориальных данных\")\n",
        "cat_cols = ['male', 'currentSmoker', 'BPMeds', 'prevalentStroke', 'prevalentHyp', 'diabetes', 'TenYearCHD']\n",
        "for col in cat_cols:\n",
        "    print(col)\n",
        "    print(df[col].value_counts())\n",
        "\n",
        "fig, axes = plt.subplots(2, 4, figsize=(16, 8))\n",
        "axes = axes.ravel()\n",
        "for i, col in enumerate(cat_cols):\n",
        "    df[col].value_counts().plot(kind='bar', ax=axes[i], color='skyblue')\n",
        "    axes[i].set_title(col)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "df.to_csv('processed_framingham.csv', index=False)\n",
        "print(\"Сохранено\")"
      ],
