      "source": [
        "\n",
        "# Глава 3. Временные ряды - NVIDIA Daily Stock Prices\n",
        "\n",
        "!pip install kagglehub -q\n",
        "import kagglehub\n",
        "\n",
        "path = kagglehub.dataset_download(\"ibrahimshahrukh/nvidia-daily-stock-prices-20162026-dataset\")\n",
        "print(f\"Датасет скачан в: {path}\")\n",
        "\n",
        "import os\n",
        "for file in os.listdir(path):\n",
        "    if file.endswith('.csv'):\n",
        "        csv_path = os.path.join(path, file)\n",
        "        print(f\"Найден файл: {file}\")\n",
        "\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from statsmodels.tsa.seasonal import seasonal_decompose\n",
        "\n",
        "df = pd.read_csv(csv_path)\n",
        "print(f\"Загружено записей: {len(df)}\")\n",
        "print(df.head())\n",
        "\n",
        "\n",
        "df['Date'] = pd.to_datetime(df['Date'])\n",
        "df.set_index('Date', inplace=True)\n",
        "df.sort_index(inplace=True)\n",
        "\n",
        "# РИСУНОК 18\n",
        "plt.figure(figsize=(14, 6))\n",
        "plt.plot(df.index, df['Close'], linewidth=1.5, color='steelblue')\n",
        "plt.title('Рисунок 18. Динамика цены закрытия акций NVIDIA (2016-2026)')\n",
        "plt.xlabel('Дата')\n",
        "plt.ylabel('Цена закрытия (доллары США)')\n",
        "plt.tight_layout()\n",
        "plt.savefig('figure_18_close_price.png', dpi=150)\n",
        "plt.show()\n",
        "\n",
        "# РИСУНОК 19\n",
        "fig, axes = plt.subplots(4, 1, figsize=(14, 10), sharex=True)\n",
        "axes[0].plot(df.index, df['Open'], linewidth=1, color='green')\n",
        "axes[0].set_ylabel('Open')\n",
        "axes[1].plot(df.index, df['High'], linewidth=1, color='red')\n",
        "axes[1].set_ylabel('High')\n",
        "axes[2].plot(df.index, df['Low'], linewidth=1, color='orange')\n",
        "axes[2].set_ylabel('Low')\n",
        "axes[3].plot(df.index, df['Close'], linewidth=1, color='steelblue')\n",
        "axes[3].set_ylabel('Close')\n",
        "axes[3].set_xlabel('Дата')\n",
        "plt.suptitle('Рисунок 19. Графики всех каналов временного ряда')\n",
        "plt.tight_layout()\n",
        "plt.savefig('figure_19_all_channels.png', dpi=150)\n",
        "plt.show()\n",
        "\n",
        "# РИСУНОК 20\n",
        "plt.figure(figsize=(10, 6))\n",
        "sns.boxplot(data=df[['Open', 'High', 'Low', 'Close']])\n",
        "plt.title('Рисунок 20. Ящичные диаграммы распределения ценовых каналов')\n",
        "plt.xlabel('Канал')\n",
        "plt.ylabel('Цена (доллары США)')\n",
        "plt.tight_layout()\n",
        "plt.savefig('figure_20_boxplots.png', dpi=150)\n",
        "plt.show()\n",
        "\n",
        "# РИСУНОК 21\n",
        "plt.figure(figsize=(10, 6))\n",
        "sns.boxplot(data=df[['Open', 'High', 'Low', 'Close']])\n",
        "plt.title('Рисунок 21. Сравнение диапазонов значений каналов')\n",
        "plt.xlabel('Канал')\n",
        "plt.ylabel('Цена (доллары США)')\n",
        "plt.tight_layout()\n",
        "plt.savefig('figure_21_ranges.png', dpi=150)\n",
        "plt.show()\n",
        "\n",
        "# РИСУНОК 22\n",
        "plt.figure(figsize=(8, 6))\n",
        "corr_matrix = df[['Open', 'High', 'Low', 'Close']].corr()\n",
        "sns.heatmap(corr_matrix, annot=True, fmt='.3f', cmap='coolwarm', square=True)\n",
        "plt.title('Рисунок 22. Тепловая карта матрицы корреляций каналов')\n",
        "plt.tight_layout()\n",
        "plt.savefig('figure_22_correlation_heatmap.png', dpi=150)\n",
        "plt.show()\n",
        "\n",
        "# РИСУНОК 23\n",
        "decomposition = seasonal_decompose(df['Close'], model='additive', period=5)\n",
        "fig, axes = plt.subplots(4, 1, figsize=(14, 10), sharex=True)\n",
        "axes[0].plot(df.index, decomposition.observed, linewidth=1, color='steelblue')\n",
        "axes[0].set_ylabel('Исходный ряд')\n",
        "axes[1].plot(df.index, decomposition.trend, linewidth=1, color='green')\n",
        "axes[1].set_ylabel('Тренд')\n",
        "axes[2].plot(df.index, decomposition.seasonal, linewidth=1, color='orange')\n",
        "axes[2].set_ylabel('Сезонность')\n",
        "axes[3].plot(df.index, decomposition.resid, linewidth=1, color='red')\n",
        "axes[3].set_ylabel('Шум (остатки)')\n",
        "axes[3].set_xlabel('Дата')\n",
        "plt.suptitle('Рисунок 23. Декомпозиция ряда цены закрытия')\n",
        "plt.tight_layout()\n",
        "plt.savefig('figure_23_decomposition.png', dpi=150)\n",
        "plt.show()\n",
        "\n",
        "# РИСУНОК 24\n",
        "residuals = decomposition.resid.dropna()\n",
        "plt.figure(figsize=(10, 6))\n",
        "plt.hist(residuals, bins=50, color='steelblue', edgecolor='black')\n",
        "plt.title('Рисунок 24. Гистограмма распределения шума (остатков)')\n",
        "plt.xlabel('Значение остатков')\n",
        "plt.ylabel('Частота')\n",
        "plt.tight_layout()\n",
        "plt.savefig('figure_24_residuals_histogram.png', dpi=150)\n",
        "plt.show()\n",
        "\n",
        "# РАСЧЁТ SNR\n",
        "signal = decomposition.trend + decomposition.seasonal\n",
        "signal_clean = signal.dropna()\n",
        "noise_clean = residuals\n",
        "var_signal = np.var(signal_clean)\n",
        "var_noise = np.var(noise_clean)\n",
        "snr = 10 * np.log10(var_signal / var_noise)\n",
        "print(f\"SNR = {snr:.2f} дБ\")\n",
        "\n",
        "# ВЫВОД СТАТИСТИКИ\n",
        "print(\"\\nСтатистические характеристики:\")\n",
        "print(df[['Open', 'High', 'Low', 'Close']].describe().round(2))\n",
        "\n",
        "print(\"\\nМатрица корреляций:\")\n",
        "print(corr_matrix.round(3))"
      ],
